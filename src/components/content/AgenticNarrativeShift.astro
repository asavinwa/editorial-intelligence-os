    display: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0.5;
    padding: 1.5rem 0.5rem 0;
    align-self: start;
  }

  @media (min-width: 640px) {
