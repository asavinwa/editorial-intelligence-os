---
interface Article {
  title: string;
  publication: string;
  url: string;
  note?: string;
}

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
---

<div class="ext-articles">
  {articles.map((article) => (
    <a href={article.url} target="_blank" rel="noopener noreferrer" class="ext-article group">
      <div class="ext-article-body">
        <div class="ext-article-pub">{article.publication} ↗</div>
        <div class="ext-article-title group-hover:text-[var(--color-accent)] transition-colors">{article.title}</div>
        {article.note && <div class="ext-article-note">{article.note}</div>}
      </div>
    </a>
  ))}
</div>

<style>
  .ext-articles {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-radius: 6px;
    overflow: hidden;
    margin: 0;
  }

  .ext-article {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-surface-secondary);
    transition: background 0.15s;
  }

  .ext-article:last-child {
    border-bottom: none;
  }

  .ext-article:hover {
    background: var(--color-surface-tertiary);
  }

  .ext-article-pub {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    opacity: 0.8;
  }

  .ext-article-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .ext-article-note {
    font-size: 0.8rem;
    color: var(--color-ink-tertiary);
    line-height: 1.5;
    margin-top: 0.1rem;
  }
</style>
