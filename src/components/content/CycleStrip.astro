---
const stages = [
  {
    label: 'Signals',
    description: 'Observations worth paying attention to',
    color: 'var(--color-ink-tertiary)',
  },
  {
    label: 'Insights',
    description: 'Patterns that reveal strategic meaning',
    color: 'var(--color-blue, #6a9fd8)',
  },
  {
    label: 'Narratives',
    description: 'Positions built from evidence over time',
    color: 'var(--color-accent)',
  },
  {
    label: 'Editorial Assets',
    description: 'Reusable articles, frameworks and tools',
    color: 'var(--color-accent)',
  },
  {
    label: 'Evidence',
    description: 'New signals generated by published work',
    color: 'var(--color-ink-tertiary)',
  },
];
---

<div class="cycle-strip">
  <div class="cycle-inner">
    <p class="t-label mb-6 cycle-header">The Editorial Intelligence Cycle</p>
    <div class="cycle-stages">
      {stages.map((stage, i) => (
        <div class="cycle-stage">
          <div class="stage-node" style={`--stage-color: ${stage.color}`}>
            <span class="stage-label">{stage.label}</span>
            <span class="stage-desc">{stage.description}</span>
          </div>
          {i < stages.length - 1 && (
            <div class="stage-arrow" aria-hidden="true">
              <svg width="20" height="12" viewBox="0 0 20 12" fill="none">
                <path d="M0 6h18M13 1l5 5-5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
          {i === stages.length - 1 && (
            <div class="stage-loop" aria-label="loops back to signals">
              <svg width="28" height="14" viewBox="0 0 28 14" fill="none">
                <path d="M2 1 C2 1, 26 1, 26 7 C26 13, 2 13, 2 13" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="none" stroke-dasharray="3 2"/>
                <path d="M6 10l-4 3 4 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" transform="translate(0,-3)"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .cycle-strip {
    border-top: 1px solid var(--color-rule, #2c2920);
    border-bottom: 1px solid var(--color-rule, #2c2920);
    background: var(--color-surface-secondary);
    padding: 2.5rem 0;
  }

  .cycle-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  .cycle-header {
    opacity: 0.6;
  }

  .cycle-stages {
    display: flex;
    align-items: flex-start;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .cycle-stages::-webkit-scrollbar {
    display: none;
  }

  .cycle-stage {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .stage-node {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 0 0.5rem;
  }

  .stage-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--stage-color, var(--color-ink));
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .stage-desc {
    font-size: 0.6875rem;
    color: var(--color-ink-tertiary);
    line-height: 1.4;
    max-width: 120px;
  }

  .stage-arrow {
    color: var(--color-rule, #2c2920);
    padding: 0 0.25rem;
    margin-bottom: 1rem;
    flex-shrink: 0;
  }

  .stage-loop {
    color: var(--color-rule, #2c2920);
    padding: 0 0.5rem;
    margin-bottom: 1rem;
    flex-shrink: 0;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .stage-desc {
      display: none;
    }
  }
</style>
