---
interface Props {
  slug: string;
  title: string;
  subtitle?: string;
  excerpt: string;
  date: Date;
  readTime: number;
  tags: string[];
  theme?: string;
  relatedFrameworks?: number;
  relatedNarratives?: number;
  relatedArticles?: number;
  featured?: boolean;
  startHere?: boolean;
}

const {
  slug,
  title,
  subtitle,
  excerpt,
  date,
  readTime,
  theme,
  relatedFrameworks = 0,
  relatedNarratives = 0,
  relatedArticles = 0,
  featured = false,
  startHere = false,
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
}).format(date);

const connectionParts: string[] = [];
if (relatedFrameworks > 0) connectionParts.push(`${relatedFrameworks} framework${relatedFrameworks > 1 ? 's' : ''}`);
if (relatedNarratives > 0) connectionParts.push(`${relatedNarratives} narrative${relatedNarratives > 1 ? 's' : ''}`);
if (relatedArticles > 0) connectionParts.push(`${relatedArticles} article${relatedArticles > 1 ? 's' : ''}`);
const connectionLabel = connectionParts.join(' · ');
---

<article class:list={['narrative-card', featured && 'narrative-card--featured']}>
  <a href={`/narratives/${slug}`} class="block no-underline group">
    {featured ? (
      <div class="featured-layout">
        <div class="featured-meta">
          {startHere && <span class="start-here-badge">Start here</span>}
          <span class="type-badge type-badge--narrative">Narrative</span>
          <span class="t-small opacity-50">{readTime} min read</span>
        </div>
        <h2 class="t-heading text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors m-0 mt-4">
          {title}
        </h2>
        {subtitle && (
          <p class="featured-subtitle m-0 mt-3">{subtitle}</p>
        )}
        <p class="t-body m-0 mt-4 leading-relaxed max-w-2xl">{excerpt}</p>
        <div class="flex items-center gap-6 mt-6 flex-wrap">
          <span class="read-more">
            Read narrative
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="inline ml-1 transition-transform group-hover:translate-x-1">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          {connectionLabel && (
            <span class="connection-label">Connects to {connectionLabel}</span>
          )}
        </div>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <span class="type-badge type-badge--narrative">Narrative</span>
            {theme && <span class="theme-label">{theme}</span>}
          </div>
          <span class="t-small opacity-50">{readTime} min</span>
        </div>
        <h2 class="t-title text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors m-0">
          {title}
        </h2>
        {subtitle && (
          <p class="t-small text-[var(--color-ink-secondary)] m-0">{subtitle}</p>
        )}
        {connectionLabel && (
          <div class="pt-2 border-t border-[var(--color-rule,#2c2920)]">
            <span class="connection-label-small">{connectionLabel}</span>
          </div>
        )}
      </div>
    )}
  </a>
</article>

<style>
  .narrative-card {
    padding: 1.75rem;
    border: 1px solid var(--color-rule, #2c2920);
    border-radius: 4px;
    transition: border-color 0.2s, background 0.2s;
    background: var(--color-surface-secondary);
  }

  .narrative-card:not(.narrative-card--featured):hover {
    border-color: var(--color-accent);
    background: var(--color-surface-tertiary);
  }

  .narrative-card--featured {
    border: 1px solid var(--color-rule, #2c2920);
    border-top: 2px solid var(--color-accent);
    border-radius: 4px;
    padding: 2.5rem;
    background: var(--color-surface-secondary);
  }

  .narrative-card--featured:hover {
    background: var(--color-surface-tertiary);
  }

  .featured-layout {
    display: flex;
    flex-direction: column;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .featured-subtitle {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-ink-secondary);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .read-more {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  .start-here-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-surface);
    background: var(--color-accent);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }

  .connection-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.02em;
  }

  .connection-label-small {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.02em;
  }

  .theme-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-tertiary);
    border: 1px solid var(--color-rule, #2c2920);
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
  }
</style>
