---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ConnectedThinking from '../../components/content/ConnectedThinking.astro';
import { getCollection, render } from 'astro:content';
import { getRelatedContent } from '../../lib/related';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const related = await getRelatedContent(entry);

const statusLabels: Record<string, string> = {
  active: 'Active experiment',
  complete: 'Complete',
  archived: 'Archived',
  draft: 'In development',
};

const statusColors: Record<string, string> = {
  active: 'var(--color-accent)',
  complete: 'var(--color-blue)',
  archived: 'var(--color-ink-tertiary)',
  draft: 'var(--color-ink-secondary)',
};

const status = entry.data.status;
const statusLabel = statusLabels[status] ?? status;
const statusColor = statusColors[status] ?? 'var(--color-ink-tertiary)';

const totalRelated =
  related.narratives.length +
  related.frameworks.length +
  related.writing.length +
  related.experiments.length;
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt}>
  <div class="container-site py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-10">
      <ol class="flex items-center gap-2 list-none m-0 p-0">
        <li><a href="/experiments" class="t-small text-[var(--color-ink-tertiary)] no-underline hover:text-[var(--color-ink)] transition-colors">Experiments</a></li>
        <li aria-hidden="true"><span class="t-small text-[var(--color-ink-tertiary)]">→</span></li>
        <li><span class="t-small text-[var(--color-ink-secondary)]">{entry.data.title}</span></li>
      </ol>
    </nav>

    <div class="detail-layout">
      <!-- Main content -->
      <article class="detail-main">
        <header class="mb-12">
          <div class="flex items-center gap-3 mb-6 flex-wrap">
            <span class="type-badge type-badge--experiment">Experiment</span>
            <span class="status-dot" style={`--dot-color: ${statusColor}`}></span>
            <span class="t-small" style={`color: ${statusColor}`}>{statusLabel}</span>
            {totalRelated > 0 && (
              <span class="t-small text-[var(--color-accent)]">{totalRelated} connected {totalRelated === 1 ? 'piece' : 'pieces'}</span>
            )}
          </div>
          <h1 class="t-heading mb-4">{entry.data.title}</h1>
          {entry.data.subtitle && (
            <p class="text-lg text-[var(--color-ink-secondary)] leading-relaxed mb-6">{entry.data.subtitle}</p>
          )}
          <p class="t-body text-[var(--color-ink-secondary)] leading-relaxed max-w-2xl">{entry.data.excerpt}</p>
        </header>

        <hr class="divider mb-10" />

        <div class="prose prose-editorial max-w-none">
          <Content />
        </div>

        {entry.data.tags.length > 0 && (
          <footer class="mt-12 pt-8 border-t border-[var(--color-surface-tertiary)]">
            <p class="t-label mb-3">Topics</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag: string) => (
                <span class="tag-pill">{tag}</span>
              ))}
            </div>
          </footer>
        )}
      </article>

      <!-- Sidebar -->
      <aside class="detail-sidebar">
        <ConnectedThinking
          narratives={related.narratives}
          frameworks={related.frameworks}
          writing={related.writing}
          experiments={related.experiments}
        />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .detail-layout {
      grid-template-columns: 1fr 280px;
      align-items: start;
    }
  }

  .detail-sidebar {
    order: -1;
  }

  @media (min-width: 1024px) {
    .detail-sidebar {
      order: 1;
    }
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dot-color, var(--color-ink-tertiary));
  }

  .type-badge--experiment {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-surface);
    background: var(--color-blue, #6a9fd8);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }
</style>
