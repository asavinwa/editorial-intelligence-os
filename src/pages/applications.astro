---
import BaseLayout from '../components/layout/BaseLayout.astro';
import EILoop from '../components/content/EILoop.astro';
---

<BaseLayout
  title="Applications"
  description="How Editorial Intelligence works in practice — applied to research, events, customer stories, AI workflows, content activation and organisational knowledge."
>
  <article class="container-site py-20">
    <div class="max-w-2xl">

      <!-- Header -->
      <header class="mb-16">
        <p class="t-label mb-6">Applications</p>
        <h1 class="t-display mb-6">How Editorial Intelligence works in practice</h1>
        <p class="t-body text-lg leading-relaxed">
          Editorial Intelligence becomes most useful when it is applied to real work: research, customer stories, events, AI workflows, campaign planning and thought leadership. These applications show how raw signals become clearer narratives, stronger assets and reusable organisational intelligence.
        </p>
      </header>

      <hr class="divider mb-16" />

      <!-- Intro -->
      <section class="mb-16">
        <div class="prose-section">
          <p>A framework is only valuable if it helps people make better decisions.</p>
          <p>The applications below show how Editorial Intelligence can be used to capture signal, synthesise patterns, activate content and create evidence that feeds future work. Each one follows the same underlying pattern — signal, synthesis, activation, evidence, learning, reuse — but produces different outputs depending on the context.</p>
        </div>
      </section>

      <hr class="divider mb-16" />

      <!-- Application cards -->
      <section class="mb-16">
        <h2 class="t-label mb-8">Applications</h2>

        <div class="app-grid">

          <!-- A: Hidden Hours -->
          <div class="app-card app-card--flagship">
            <div class="app-card-header">
              <div>
                <h3 class="app-title">Hidden Hours</h3>
                <p class="app-desc">Using research, practitioner insight and content activation to reveal the unseen work shaping modern accountancy.</p>
              </div>
              <span class="app-status app-status--flagship">Flagship proof point</span>
            </div>
            <div class="app-meta">
              <div class="app-meta-row">
                <span class="app-meta-label">Source signals</span>
                <span class="app-meta-value">Survey research, accountant interviews, Accountex, policy change, client behaviour</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Activated outputs</span>
                <span class="app-meta-value">Articles, diagnostic, event content, newsletter, social and video</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Intelligence created</span>
                <span class="app-meta-value">Operational pressure narrative, hidden work model, diagnostic types, AI and workflow opportunities</span>
              </div>
            </div>
            <a href="/narratives/hidden-hours" class="app-link">Read the narrative →</a>
          </div>

          <!-- B: Event intelligence -->
          <div class="app-card">
            <div class="app-card-header">
              <div>
                <h3 class="app-title">Event intelligence</h3>
                <p class="app-desc">Turning events from one-off moments into reusable insight systems.</p>
              </div>
              <span class="app-status app-status--active">Active</span>
            </div>
            <div class="app-meta">
              <div class="app-meta-row">
                <span class="app-meta-label">Source signals</span>
                <span class="app-meta-value">Practitioner panels, event themes, audience questions, speaker interviews, session takeaways</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Activated outputs</span>
                <span class="app-meta-value">Event reports, articles, stakeholder briefings, social clips, narrative decks</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Intelligence created</span>
                <span class="app-meta-value">Market signals, audience pain points, repeatable thought leadership themes</span>
              </div>
            </div>
            <a href="/experiments/event-intelligence" class="app-link">See the experiment →</a>
          </div>

          <!-- C: Customer story intelligence -->
          <div class="app-card">
            <div class="app-card-header">
              <div>
                <h3 class="app-title">Customer story intelligence</h3>
                <p class="app-desc">Using customer stories to reveal patterns of operational change, not just individual success.</p>
              </div>
              <span class="app-status app-status--active">Active</span>
            </div>
            <div class="app-meta">
              <div class="app-meta-row">
                <span class="app-meta-label">Source signals</span>
                <span class="app-meta-value">Customer interviews, implementation stories, before/after change, partner input, product adoption</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Activated outputs</span>
                <span class="app-meta-value">Case studies, web stories, sales proof, industry narratives</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Intelligence created</span>
                <span class="app-meta-value">Common pain points, transformation patterns, proof themes, better briefing inputs</span>
              </div>
            </div>
            <a href="/narratives/customer-stories" class="app-link">Read the narrative →</a>
          </div>

          <!-- D: AI workflow demonstrations -->
          <div class="app-card">
            <div class="app-card-header">
              <div>
                <h3 class="app-title">AI workflow demonstrations</h3>
                <p class="app-desc">Showing how AI can support research, synthesis, briefing, diagnostics and editorial systems.</p>
              </div>
              <span class="app-status app-status--dev">In development</span>
            </div>
            <div class="app-meta">
              <div class="app-meta-row">
                <span class="app-meta-label">Source signals</span>
                <span class="app-meta-value">Prompt experiments, workflow tests, diagnostic prototypes, AI search behaviour, content processes</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Activated outputs</span>
                <span class="app-meta-value">Prompt architectures, workflow demos, diagnostic tools, framework pages</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Intelligence created</span>
                <span class="app-meta-value">Reusable methods, faster synthesis, better knowledge retrieval, clearer editorial systems</span>
              </div>
            </div>
            <a href="/experiments" class="app-link">See all experiments →</a>
          </div>

          <!-- E: Content activation -->
          <div class="app-card">
            <div class="app-card-header">
              <div>
                <h3 class="app-title">Content activation</h3>
                <p class="app-desc">Connecting research and market signals to articles, video, social, newsletters and community discussion.</p>
              </div>
              <span class="app-status app-status--active">Framework live</span>
            </div>
            <div class="app-meta">
              <div class="app-meta-row">
                <span class="app-meta-label">Source signals</span>
                <span class="app-meta-value">Research, customer stories, events, advisory boards, market change</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Activated outputs</span>
                <span class="app-meta-value">Articles, video, LinkedIn, newsletters, community discussion, internal briefings</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Intelligence created</span>
                <span class="app-meta-value">Narrative feedback, audience response, stronger campaign direction, reusable positioning</span>
              </div>
            </div>
            <a href="/frameworks/content-activation-framework" class="app-link">Read the framework →</a>
          </div>

          <!-- F: Editorial Intelligence OS -->
          <div class="app-card">
            <div class="app-card-header">
              <div>
                <h3 class="app-title">Editorial Intelligence OS</h3>
                <p class="app-desc">The operating system that connects signals, synthesis, activation and evidence across the work.</p>
              </div>
              <span class="app-status app-status--core">Core system</span>
            </div>
            <div class="app-meta">
              <div class="app-meta-row">
                <span class="app-meta-label">Source signals</span>
                <span class="app-meta-value">Daily work, stakeholder needs, customer insight, market research, experiments</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Activated outputs</span>
                <span class="app-meta-value">Frameworks, dashboards, briefs, articles, case studies, playbooks</span>
              </div>
              <div class="app-meta-row">
                <span class="app-meta-label">Intelligence created</span>
                <span class="app-meta-value">Connected knowledge, reusable methods, stronger editorial capability</span>
              </div>
            </div>
            <a href="/dashboard" class="app-link">See the Dashboard OS →</a>
          </div>

        </div>
      </section>

      <hr class="divider mb-16" />

      <!-- AI systems callout -->
      <section class="mb-16">
        <div class="ai-systems-callout">
          <div class="ai-systems-callout-body">
            <p class="t-label mb-2">AI systems</p>
            <h2 class="ai-systems-callout-title">From content systems to AI systems</h2>
            <p class="ai-systems-callout-desc">As AI models become easier to access, the advantage shifts to organisations that can orchestrate knowledge, memory, judgement and execution. Editorial Intelligence is the layer that connects them.</p>
          </div>
          <a href="/ai-systems" class="ai-systems-callout-link">
            Explore the orchestration model
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </section>

    </div><!-- /max-w-2xl -->

    <!-- How the applications work — full container width -->
    <section class="mb-16">
      <div class="max-w-2xl mb-8">
        <h2 class="t-label mb-8">How the applications work</h2>
        <div class="prose-section">
          <p>Each application follows the same underlying pattern. The context changes — research, events, customer stories, AI workflows — but the logic is consistent.</p>
        </div>
      </div>
      <EILoop />
      <div class="app-loop-explainer mt-8 max-w-2xl mx-auto">
        <p>Editorial Intelligence works as a loop. Signals are captured from research, customers, events and market change. They are synthesised into patterns and narratives, activated through content and campaigns, tested through evidence, and reused as intelligence that shapes future work.</p>
      </div>
    </section>

    <div class="max-w-2xl">

      <hr class="divider mb-16" />

      <!-- Why this matters -->
      <section class="mb-16">
        <h2 class="t-label mb-8">Why this matters</h2>
        <div class="prose-section">
          <p>Most organisations already have valuable signals scattered across research, customer conversations, events, content performance, sales feedback and internal expertise.</p>
          <p>The problem is not the absence of insight. The problem is that insight is rarely connected, activated and reused. Each project starts from approximately the same base as the last. The organisation gets better at execution but not at understanding.</p>
          <p class="font-medium text-[var(--color-ink)]">Editorial Intelligence turns those scattered signals into a working knowledge system.</p>
          <p>The applications above are examples of that system in practice — not a portfolio of completed projects, but a set of repeatable methods that improve with each pass through the cycle.</p>
        </div>
      </section>

      <hr class="divider mb-16" />

      <!-- Internal links -->
      <section class="mb-8">
        <h2 class="t-label mb-8">Explore further</h2>
        <div class="explore-links">
          <a href="/intelligence" class="explore-link">
            <span class="explore-link-title">What is Editorial Intelligence?</span>
            <span class="explore-link-desc">The discipline and the cycle that powers it</span>
          </a>
          <a href="/frameworks" class="explore-link">
            <span class="explore-link-title">Frameworks</span>
            <span class="explore-link-desc">Reusable methods and models</span>
          </a>
          <a href="/narratives" class="explore-link">
            <span class="explore-link-title">Narratives</span>
            <span class="explore-link-desc">Strategic positions built from evidence</span>
          </a>
          <a href="/ai-systems" class="explore-link">
            <span class="explore-link-title">AI systems</span>
            <span class="explore-link-desc">The orchestration layer between knowledge and AI execution</span>
          </a>
          <a href="/experiments" class="explore-link">
            <span class="explore-link-title">Experiments</span>
            <span class="explore-link-desc">Active workflows and tools under development</span>
          </a>
          <a href="/practice" class="explore-link">
            <span class="explore-link-title">In practice</span>
            <span class="explore-link-desc">Evidence of the work and how it compounds</span>
          </a>
        </div>
      </section>

    </div>
  </article>
</BaseLayout>

<style>
  .prose-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .prose-section p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-ink-secondary);
  }

  /* Application cards */
  .app-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .app-card {
    border: 1px solid var(--color-rule);
    border-radius: 6px;
    padding: 1.5rem;
    background: var(--color-surface-secondary);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .app-card--flagship {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface));
  }

  .app-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .app-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem 0;
  }

  .app-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-secondary);
    margin: 0;
  }

  .app-status {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .app-status--flagship {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .app-status--active {
    background: var(--color-surface);
    color: var(--color-ink-tertiary);
    border: 1px solid var(--color-rule);
  }

  .app-status--dev {
    background: var(--color-surface);
    color: var(--color-ink-tertiary);
    border: 1px solid var(--color-rule);
    opacity: 0.7;
  }

  .app-status--core {
    background: var(--color-surface);
    color: var(--color-ink-tertiary);
    border: 1px solid var(--color-rule);
  }

  .app-meta {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1rem;
    background: var(--color-surface);
    border-radius: 4px;
    border: 1px solid var(--color-rule);
  }

  .app-meta-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }

  .app-meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .app-meta-value {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-secondary);
  }

  .app-link {
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    padding-bottom: 1px;
    align-self: flex-start;
    transition: border-color 0.15s;
  }

  .app-link:hover {
    border-color: var(--color-accent);
  }

  .app-loop-explainer p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-ink-tertiary);
    text-align: center;
    max-width: 52ch;
    margin: 0 auto;
  }

  /* Explore links */
  .explore-links {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-radius: 6px;
    overflow: hidden;
  }

  .explore-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    transition: background 0.15s;
  }

  .explore-link:last-child {
    border-bottom: none;
  }

  .explore-link:hover {
    background: var(--color-surface-secondary);
  }

  .explore-link-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: color 0.15s;
  }

  .explore-link:hover .explore-link-title {
    color: var(--color-accent);
  }

  .explore-link-desc {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-tertiary);
    letter-spacing: 0.02em;
  }

  /* AI systems callout */
  .ai-systems-callout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.75rem;
    border: 1px solid var(--color-rule);
    border-left: 2px solid var(--color-accent);
    border-radius: 5px;
    background: var(--color-surface-secondary);
  }

  @media (min-width: 640px) {
    .ai-systems-callout {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .ai-systems-callout-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem 0;
  }

  .ai-systems-callout-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink-secondary);
    margin: 0;
    max-width: 44ch;
  }

  .ai-systems-callout-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    padding-bottom: 1px;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }

  .ai-systems-callout-link:hover {
    border-color: var(--color-accent);
  }
</style>
