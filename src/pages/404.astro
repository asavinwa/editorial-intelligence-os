---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="container-site py-32 text-center">
    <p class="t-label mb-6">404</p>
    <h1 class="t-heading mb-6">Page not found</h1>
    <p class="t-body mb-8 max-w-md mx-auto">
      This signal doesn't connect to anything in the system yet.
    </p>
    <div class="flex flex-col items-center gap-3">
      <a href="/" class="t-small text-[var(--color-accent)] no-underline hover:underline">
        Return home →
      </a>
      <a href="/start" class="t-small text-[var(--color-ink-tertiary)] no-underline hover:text-[var(--color-ink)]">
        Not sure where to go? Start here →
      </a>
    </div>
  </div>
</BaseLayout>
