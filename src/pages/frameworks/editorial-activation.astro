---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Editorial Activation Framework | Editorial Intelligence"
  description="Learn how Editorial Activation turns research, customer insight, expertise and market signals into connected thought leadership, PR, social, sales and customer marketing outcomes."
>

  <!-- Breadcrumb -->
  <div class="container-site pt-10 pb-0">
    <nav aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 list-none m-0 p-0">
        <li><a href="/frameworks" class="t-small text-[var(--color-ink-tertiary)] no-underline hover:text-[var(--color-ink)] transition-colors">Frameworks</a></li>
        <li aria-hidden="true"><span class="t-small text-[var(--color-ink-tertiary)]">→</span></li>
        <li><span class="t-small text-[var(--color-ink-secondary)]">Editorial Activation</span></li>
      </ol>
    </nav>
  </div>

  <!-- Hero -->
  <section class="ea-hero">
    <div class="container-site py-20">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="type-badge type-badge--framework">Framework · Process</span>
        </div>
        <h1 class="t-display mb-4">Editorial Activation</h1>
        <p class="ea-subtitle mb-8">Turning evidence into organisational impact.</p>
        <div class="ea-intro">
          <p>Most organisations are good at creating content.</p>
          <p>Far fewer are good at activating knowledge.</p>
          <p>Research is published once. Events become recap articles. Executive expertise remains in people's heads. Customer insight disappears into transcripts. Valuable evidence is repeatedly recreated rather than reused.</p>
          <p>Editorial Activation is the discipline of turning organisational knowledge into connected, reusable outputs across editorial, thought leadership, PR, social, events, sales and customer marketing.</p>
          <p>It does not begin with the question: <em>"What content can we make from this asset?"</em></p>
          <p>It begins with: <em>"What knowledge have we created, and how can it generate sustained value?"</em></p>
        </div>
        <div class="ea-ctas mt-10">
          <a href="#framework" class="ea-cta-primary">Explore the framework</a>
          <a href="/editorial-intelligence-os" class="ea-cta-secondary">Editorial Intelligence OS →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Definition panel -->
  <section class="ea-definition-panel">
    <div class="container-site py-12">
      <div class="max-w-2xl">
        <p class="t-label mb-6">What is Editorial Activation?</p>
        <div class="ea-def-prose mb-8">
          <p>Editorial Activation is the part of the Editorial Operating System that turns evidence and narratives into coordinated communication, experiences and organisational tools.</p>
          <p>It connects upstream intelligence with downstream execution.</p>
          <p>The process begins with signals — research, customer conversations, executive expertise, events and market change. Editorial Intelligence connects and synthesises those signals. Narrative Architecture gives them structure. Editorial Activation then translates that shared understanding into useful outputs across multiple teams and channels.</p>
          <p>The result is not more disconnected content. It is a coordinated system in which every output reinforces the same evidence base and strategic narrative.</p>
        </div>
        <blockquote class="ea-definition-quote">
          Editorial Activation turns organisational knowledge into connected action across channels.
        </blockquote>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Framework diagram -->
  <section id="framework" class="container-site py-16">
    <p class="t-label mb-10">The framework</p>

    <div class="ea-flow" role="img" aria-label="Editorial Activation framework: Inputs flow through Editorial Intelligence, Narrative Architecture and Editorial Activation into channels, generating learning that feeds back into the system">

      <!-- Inputs -->
      <div class="ea-flow-stage ea-flow-stage--inputs">
        <div class="ea-flow-stage-header">
          <span class="ea-stage-num">Inputs</span>
          <p class="ea-stage-title">Organisational knowledge</p>
        </div>
        <ul class="ea-flow-items">
          <li>Research</li>
          <li>Customer insight</li>
          <li>Executive expertise</li>
          <li>Events</li>
          <li>Market signals</li>
          <li>Operational knowledge</li>
        </ul>
      </div>

      <div class="ea-flow-arrow" aria-hidden="true">↓</div>

      <!-- Editorial Intelligence -->
      <div class="ea-flow-stage ea-flow-stage--ei">
        <div class="ea-flow-stage-header">
          <span class="ea-stage-num">01</span>
          <p class="ea-stage-title">Editorial Intelligence</p>
        </div>
        <ul class="ea-flow-items">
          <li>Capture</li>
          <li>Connect</li>
          <li>Synthesise</li>
          <li>Prioritise</li>
        </ul>
      </div>

      <div class="ea-flow-arrow" aria-hidden="true">↓</div>

      <!-- Narrative Architecture -->
      <div class="ea-flow-stage ea-flow-stage--na">
        <div class="ea-flow-stage-header">
          <span class="ea-stage-num">02</span>
          <p class="ea-stage-title">Narrative Architecture</p>
        </div>
        <ul class="ea-flow-items">
          <li>Frame the problem</li>
          <li>Connect the evidence</li>
          <li>Establish the throughline</li>
          <li>Create reusable narrative components</li>
        </ul>
      </div>

      <div class="ea-flow-arrow" aria-hidden="true">↓</div>

      <!-- Editorial Activation — highlighted -->
      <div class="ea-flow-stage ea-flow-stage--activation ea-flow-stage--current">
        <div class="ea-flow-stage-header">
          <span class="ea-stage-num">03</span>
          <p class="ea-stage-title">Editorial Activation</p>
        </div>
        <ul class="ea-flow-items">
          <li>Coordinate</li>
          <li>Adapt</li>
          <li>Publish</li>
          <li>Enable</li>
          <li>Amplify</li>
        </ul>
      </div>

      <div class="ea-flow-arrow" aria-hidden="true">↓</div>

      <!-- Channels -->
      <div class="ea-flow-stage ea-flow-stage--channels">
        <div class="ea-flow-stage-header">
          <span class="ea-stage-num">Channels</span>
          <p class="ea-stage-title">Activation channels</p>
        </div>
        <ul class="ea-flow-items ea-flow-items--wrap">
          <li>Editorial</li>
          <li>Thought leadership</li>
          <li>PR</li>
          <li>Social</li>
          <li>Events</li>
          <li>Customer marketing</li>
          <li>Sales enablement</li>
          <li>Executive communications</li>
          <li>AI visibility</li>
        </ul>
      </div>

      <div class="ea-flow-arrow" aria-hidden="true">↓</div>

      <!-- Learning -->
      <div class="ea-flow-stage ea-flow-stage--learning">
        <div class="ea-flow-stage-header">
          <span class="ea-stage-num">Learning</span>
          <p class="ea-stage-title">Evidence and signals</p>
        </div>
        <ul class="ea-flow-items ea-flow-items--wrap">
          <li>Engagement patterns</li>
          <li>Media response</li>
          <li>Customer feedback</li>
          <li>Sales questions</li>
          <li>Search and AI visibility</li>
          <li>New market signals</li>
        </ul>
      </div>

      <!-- Loop back indicator -->
      <div class="ea-flow-loop" aria-hidden="true">
        <div class="ea-loop-line"></div>
        <span class="ea-loop-label">feeds back to Editorial Intelligence</span>
      </div>

    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Comparison: content repurposing vs Editorial Activation -->
  <section class="container-site py-16">
    <p class="t-label mb-10">From content repurposing to Editorial Activation</p>
    <div class="ea-comparison">

      <div class="ea-compare-card ea-compare-card--left">
        <p class="ea-compare-title">Content repurposing</p>
        <p class="ea-compare-sub">Starts with an existing asset.</p>
        <div class="ea-compare-section">
          <p class="ea-compare-label">Typical process</p>
          <ul>
            <li>Publish a report</li>
            <li>Extract an article</li>
            <li>Create social posts</li>
            <li>Cut a video</li>
            <li>Send a newsletter</li>
            <li>Move on</li>
          </ul>
        </div>
        <div class="ea-compare-section">
          <p class="ea-compare-label">Primary goal</p>
          <p>Get more outputs from one asset.</p>
        </div>
        <div class="ea-compare-section">
          <p class="ea-compare-label">Limitation</p>
          <p>The activity often ends when the campaign ends.</p>
        </div>
      </div>

      <div class="ea-compare-card ea-compare-card--right">
        <p class="ea-compare-title">Editorial Activation</p>
        <p class="ea-compare-sub">Starts with organisational knowledge.</p>
        <div class="ea-compare-section">
          <p class="ea-compare-label">Typical process</p>
          <ul>
            <li>Capture evidence</li>
            <li>Identify recurring patterns</li>
            <li>Develop a strategic narrative</li>
            <li>Coordinate activation across teams</li>
            <li>Collect new signals</li>
            <li>Improve the narrative over time</li>
          </ul>
        </div>
        <div class="ea-compare-section">
          <p class="ea-compare-label">Primary goal</p>
          <p>Create sustained value from a shared evidence base.</p>
        </div>
        <div class="ea-compare-section">
          <p class="ea-compare-label">Outcome</p>
          <p>A connected editorial system that becomes more useful with every activation cycle.</p>
        </div>
      </div>

    </div>

    <p class="ea-compare-conclusion">Repurposing multiplies assets. Editorial Activation compounds knowledge.</p>
  </section>

  <hr class="divider container-site" />

  <!-- What can be activated -->
  <section class="container-site py-16">
    <p class="t-label mb-10">What organisations can activate</p>
    <div class="ea-source-grid">

      {[
        {
          title: 'Research',
          desc: 'Turn a report into a year-long evidence programme rather than a one-off launch.',
          outputs: ['Narrative hub', 'Thought leadership', 'PR', 'Customer interviews', 'Events', 'Sales enablement', 'Future research questions'],
        },
        {
          title: 'Customer insight',
          desc: 'Turn interviews, conversations and recurring customer problems into reusable evidence.',
          outputs: ['Customer stories', 'Audience language', 'Editorial themes', 'FAQs', 'Product insight', 'Sales messaging'],
        },
        {
          title: 'Executive expertise',
          desc: 'Turn practitioner knowledge into visible and credible organisational authority.',
          outputs: ['Executive articles', 'Keynotes', 'Commentary', 'LinkedIn', 'Media opportunities', 'Internal learning'],
        },
        {
          title: 'Events',
          desc: 'Treat events as intelligence-gathering opportunities rather than isolated content moments.',
          outputs: ['Signals', 'Quotes', 'Frameworks', 'Editorial opportunities', 'Strategic recommendations', 'Follow-up discussions'],
        },
        {
          title: 'Market signals',
          desc: 'Connect fragmented market changes into a coherent point of view.',
          outputs: ['Trend narratives', 'Briefings', 'Strategic commentary', 'Thought leadership', 'Campaign themes', 'Product positioning'],
        },
        {
          title: 'Operational knowledge',
          desc: 'Turn internal experience and repeatable practice into organisational assets.',
          outputs: ['Playbooks', 'Guides', 'Workflows', 'Glossaries', 'AI agents', 'Training'],
        },
      ].map((card) => (
        <div class="ea-source-card">
          <h3 class="ea-source-card__title">{card.title}</h3>
          <p class="ea-source-card__desc">{card.desc}</p>
          <div class="ea-source-card__outputs">
            <p class="ea-source-card__label">Possible outputs</p>
            <ul class="ea-source-card__list">
              {card.outputs.map((o) => <li>{o}</li>)}
            </ul>
          </div>
        </div>
      ))}

    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Channels section -->
  <section class="container-site py-16">
    <p class="t-label mb-4">One narrative, multiple expressions</p>
    <div class="max-w-2xl mb-10">
      <p class="ea-section-intro">Editorial Activation does not require every channel to publish the same message in the same format. It requires every channel to draw from the same evidence and narrative foundation.</p>
    </div>

    <div class="ea-channel-grid">
      {[
        { name: 'Editorial', desc: 'Articles, guides, framework pages, narrative hubs and newsletters.' },
        { name: 'Thought leadership', desc: 'Executive points of view, keynote narratives, long-form essays and research-led commentary.' },
        { name: 'PR', desc: 'Media stories, expert commentary, research narratives and reactive opportunities.' },
        { name: 'Social', desc: 'Short-form ideas, video, practitioner perspectives and audience discussion.' },
        { name: 'Events', desc: 'Talks, roundtables, panels, workshops and post-event intelligence.' },
        { name: 'Customer marketing', desc: 'Customer stories, advocacy, proof points and peer evidence.' },
        { name: 'Sales enablement', desc: 'Talking points, objection handling, evidence libraries and buyer education.' },
        { name: 'AI visibility', desc: 'Structured evidence, consistent definitions, credible sources and connected authority signals.' },
      ].map((ch) => (
        <div class="ea-channel-card">
          <p class="ea-channel-name">{ch.name}</p>
          <p class="ea-channel-desc">{ch.desc}</p>
        </div>
      ))}
    </div>

    <p class="ea-channel-statement">PR, social, editorial and sales are not separate endings. They are different expressions of the same intelligence.</p>
  </section>

  <hr class="divider container-site" />

  <!-- Hidden Hours example -->
  <section class="container-site py-16">
    <div class="max-w-3xl">
      <p class="t-label mb-2">Editorial Activation in practice</p>
      <h2 class="t-heading mb-4">Hidden Hours</h2>
      <p class="ea-section-intro mb-10">Hidden Hours demonstrates how one research programme can become a connected editorial system rather than a campaign that ends after publication.</p>

      <div class="ea-example-flow">

        <div class="ea-example-step">
          <div class="ea-example-step__marker">
            <span class="ea-example-step__stage">Evidence source</span>
            <div class="ea-example-step__line" aria-hidden="true"></div>
          </div>
          <p class="ea-example-step__text">Hidden Hours research into the unseen work performed by accountants and bookkeepers — compliance burden, workflow friction, late payments, business change absorbed in silence.</p>
        </div>

        <div class="ea-example-step">
          <div class="ea-example-step__marker">
            <span class="ea-example-step__stage">Narrative</span>
            <div class="ea-example-step__line" aria-hidden="true"></div>
          </div>
          <p class="ea-example-step__text">The most valuable work is often hidden, undervalued and performed outside the formal scope of the accountant-client relationship.</p>
        </div>

        <div class="ea-example-step">
          <div class="ea-example-step__marker">
            <span class="ea-example-step__stage">Activation</span>
            <div class="ea-example-step__line" aria-hidden="true"></div>
          </div>
          <div class="ea-example-step__content">
            <ul class="ea-example-step__list">
              <li>Research report</li>
              <li>Editorial articles</li>
              <li>Event conversations</li>
              <li>Customer and practitioner stories</li>
              <li>Business-owner perspective content</li>
              <li>Newsletter distribution</li>
              <li>LinkedIn content</li>
              <li>PR opportunities</li>
              <li>Diagnostic concept</li>
              <li>Sales and stakeholder messaging</li>
              <li>Future research questions</li>
            </ul>
          </div>
        </div>

        <div class="ea-example-step">
          <div class="ea-example-step__marker">
            <span class="ea-example-step__stage">Learning</span>
          </div>
          <div class="ea-example-step__content">
            <ul class="ea-example-step__list">
              <li>Which themes resonate with practitioners</li>
              <li>Which language accountants use to describe pressure</li>
              <li>Which outputs create engagement and conversation</li>
              <li>Which evidence needs strengthening</li>
              <li>Where the narrative should evolve next</li>
            </ul>
          </div>
        </div>

      </div>

      <div class="ea-example-conclusion mt-10">
        <p>The value is not the number of assets created.</p>
        <p>The value is that every output deepens and extends the same strategic narrative.</p>
      </div>

      <a href="/narratives/hidden-hours" class="ea-example-link mt-6">Read the Hidden Hours narrative →</a>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Five principles -->
  <section class="container-site py-16">
    <div class="max-w-2xl">
      <p class="t-label mb-10">Five principles of Editorial Activation</p>
      <div class="ea-principles">

        {[
          {
            num: '01',
            title: 'Evidence before content',
            body: 'Begin with what the organisation knows, not with a format request. Research, customer conversations, operational experience and market signals are the raw material. Content is the expression of that material — not the starting point.',
          },
          {
            num: '02',
            title: 'Narratives before campaigns',
            body: 'Define the enduring strategic idea before planning individual outputs. A narrative connects evidence across time and provides the foundation that every channel draws from. Campaigns have a beginning and an end. Narratives evolve.',
          },
          {
            num: '03',
            title: 'Systems before assets',
            body: 'Design how knowledge will be captured, reused and improved — not just what will be published. The organisation that builds an editorial system gets stronger with each cycle. The one that produces isolated assets resets with each campaign.',
          },
          {
            num: '04',
            title: 'Coordination without duplication',
            body: 'Different teams and channels should adapt the narrative for their audience while drawing from the same evidence base. PR, social, sales and editorial do not need identical messaging. They need a shared foundation.',
          },
          {
            num: '05',
            title: 'Learning closes the loop',
            body: 'Every activation should generate new signals that strengthen future editorial decisions. Engagement, questions, media responses and sales conversations are not just metrics — they are intelligence that improves the next cycle.',
          },
        ].map((p) => (
          <div class="ea-principle">
            <div class="ea-principle__header">
              <span class="ea-principle__num">{p.num}</span>
              <h3 class="ea-principle__title">{p.title}</h3>
            </div>
            <p class="ea-principle__body">{p.body}</p>
          </div>
        ))}

      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Where it fits in EOS -->
  <section class="container-site py-16">
    <div class="max-w-2xl">
      <p class="t-label mb-10">Where Editorial Activation fits</p>

      <div class="ea-architecture mb-10">
        {[
          { label: 'Editorial Intelligence', href: '/intelligence', sub: 'The discipline' },
          { label: 'Editorial Operating System', href: '/editorial-intelligence-os', sub: 'The practical OS' },
          { label: 'Evidence Engine', href: '/frameworks/evidence-engine', sub: 'Captures and organises proof' },
          { label: 'Narrative Architecture', href: '/frameworks/narrative-architecture', sub: 'Turns evidence into strategic stories' },
          { label: 'Editorial Activation', href: null, sub: 'Translates narrative into coordinated outputs', current: true },
          { label: 'Learning and continuous improvement', href: null, sub: 'Evidence feeds back into the system' },
        ].map((item, i) => (
          <div class="ea-arch-row">
            {i > 0 && <div class="ea-arch-connector" aria-hidden="true">↓</div>}
            {item.href ? (
              <a href={item.href} class:list={['ea-arch-item', item.current && 'ea-arch-item--current']}>
                <span class="ea-arch-label">{item.label}</span>
                <span class="ea-arch-sub">{item.sub}</span>
              </a>
            ) : (
              <div class:list={['ea-arch-item', item.current && 'ea-arch-item--current']}>
                <span class="ea-arch-label">{item.label}</span>
                <span class="ea-arch-sub">{item.sub}</span>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="ea-arch-prose">
        <p>Editorial Activation is not the whole operating system.</p>
        <p>It depends on upstream capabilities:</p>
        <ul>
          <li>The <a href="/frameworks/evidence-engine">Evidence Engine</a> captures and organises proof.</li>
          <li><a href="/frameworks/narrative-architecture">Narrative Architecture</a> turns evidence into a coherent strategic story.</li>
          <li>Editorial Activation translates that narrative into coordinated outputs and experiences.</li>
          <li>Measurement and learning feed new signals back into the system.</li>
        </ul>
        <p>This is how Editorial Intelligence moves from insight to action.</p>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Maturity model -->
  <section class="container-site py-16">
    <p class="t-label mb-10">Editorial Activation maturity</p>
    <div class="ea-maturity-grid">

      {[
        {
          stage: 'Stage 1',
          label: 'Asset-led',
          desc: 'Teams begin with a content asset and create a few derivative outputs.',
          characteristics: ['Campaign-based', 'Channel-specific', 'Limited reuse', 'Little structured learning'],
        },
        {
          stage: 'Stage 2',
          label: 'Narrative-led',
          desc: 'Teams organise multiple outputs around a shared strategic narrative.',
          characteristics: ['Better consistency', 'Connected messaging', 'Cross-channel planning', 'Evidence used more than once'],
        },
        {
          stage: 'Stage 3',
          label: 'System-led',
          desc: 'Teams manage evidence, narratives, activation and learning as a repeatable operating model.',
          characteristics: ['Shared evidence base', 'Coordinated teams', 'Reusable workflows', 'Defined feedback loops'],
        },
        {
          stage: 'Stage 4',
          label: 'Intelligence-led',
          desc: 'Editorial Intelligence continuously identifies opportunities and activates organisational knowledge across channels.',
          characteristics: ['Ongoing signal capture', 'AI-supported workflows', 'Organisational memory', 'Compounding authority', 'Faster strategic response'],
        },
      ].map((m, i) => (
        <div class="ea-maturity-card" style={`--stage-idx: ${i}`}>
          <div class="ea-maturity-card__header">
            <span class="ea-maturity-card__stage">{m.stage}</span>
            <p class="ea-maturity-card__label">{m.label}</p>
          </div>
          <p class="ea-maturity-card__desc">{m.desc}</p>
          <ul class="ea-maturity-card__list">
            {m.characteristics.map((c) => <li>{c}</li>)}
          </ul>
        </div>
      ))}

    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Diagnostic questions -->
  <section class="container-site py-16">
    <div class="max-w-2xl">
      <p class="t-label mb-10">Questions to assess Editorial Activation</p>
      <ul class="ea-diagnostic-list">
        {[
          'Does research continue creating value after launch?',
          'Can teams find and reuse customer evidence?',
          'Do PR, editorial, social and sales draw from the same narrative?',
          'Are executive interviews reused beyond one article?',
          'Do events produce strategic learning as well as content?',
          'Can teams explain which narrative each asset supports?',
          'Does performance data influence future editorial decisions?',
          'Are insights stored somewhere people can find them?',
          'Can AI systems access reliable organisational knowledge?',
          'Does each campaign strengthen a longer-term authority position?',
        ].map((q) => (
          <li class="ea-diagnostic-item">
            <span class="ea-diagnostic-check" aria-hidden="true">◻</span>
            <span>{q}</span>
          </li>
        ))}
      </ul>
      <div class="mt-10">
        <a href="/assessment" class="ea-cta-primary">Assess your Editorial Intelligence capability →</a>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Related frameworks -->
  <section class="container-site py-16">
    <p class="t-label mb-8">Related frameworks and tools</p>
    <div class="ea-related-grid">
      {[
        { label: 'Editorial Intelligence OS', href: '/editorial-intelligence-os', desc: 'The practical operating system this framework sits within.' },
        { label: 'Evidence Engine', href: '/frameworks/evidence-engine', desc: 'How organisations capture and connect signals before activation.' },
        { label: 'Narrative Architecture', href: '/frameworks/narrative-architecture', desc: 'The structural layer between evidence and activation.' },
        { label: 'AI Visibility & Buyability', href: '/frameworks/ai-visibility-buyability', desc: 'How activated content influences AI discovery and buyer confidence.' },
        { label: 'Customer Signal Framework', href: '/frameworks/customer-signal-framework', desc: 'How customer evidence is identified and organised for activation.' },
        { label: 'Event Intelligence', href: '/experiments/event-intelligence', desc: 'Turning event conversations into reusable strategic intelligence.' },
      ].map((r) => (
        <a href={r.href} class="ea-related-card">
          <p class="ea-related-card__label">{r.label}</p>
          <p class="ea-related-card__desc">{r.desc}</p>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .ea-hero {
    border-bottom: 1px solid var(--color-rule, #2c2920);
    background: var(--color-surface);
  }

  .ea-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.5vw, 1.375rem);
    font-weight: 400;
    color: var(--color-ink-secondary);
    letter-spacing: -0.01em;
  }

  .ea-intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ea-intro p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-ink-secondary);
    max-width: 58ch;
  }

  .ea-intro em {
    color: var(--color-ink);
    font-style: italic;
  }

