---
import BaseLayout from '../components/layout/BaseLayout.astro';
import NarrativeCard from '../components/content/NarrativeCard.astro';
import FrameworkCard from '../components/content/FrameworkCard.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';

const allNarratives = await getCollection('narratives', ({ data }) => data.status === 'published');
const allFrameworks = await getCollection('frameworks', ({ data }) => data.status === 'published');
const allWriting = await getCollection('writing', ({ data }) => data.status === 'published');

const featuredNarrative = allNarratives.find((n) => n.data.featuredOnHome) ?? allNarratives[0];

const featuredRelatedArticleSlugs = featuredNarrative?.data.relatedArticles ?? [];
const featuredRelatedArticles = allWriting.filter(w => featuredRelatedArticleSlugs.includes(w.slug));

const featuredRelatedFrameworkSlugs = featuredNarrative?.data.relatedFrameworks ?? [];
const featuredRelatedFrameworks = allFrameworks.filter(f => featuredRelatedFrameworkSlugs.includes(f.slug));

const remainingFrameworks = allFrameworks
  .filter(f => !featuredRelatedFrameworkSlugs.includes(f.slug))
  .slice(0, 2);
---

<BaseLayout>
  <!-- Hero -->
  <section class="container-site pt-28 pb-10 md:pt-36 md:pb-12">
    <div class="max-w-3xl">
      <p class="t-label mb-10">{SITE.author} · Content strategist at Sage</p>
      <h1 class="t-display text-[var(--color-ink)] mb-3 leading-[1.08]">
        Editorial Intelligence<br />for the AI era
      </h1>
      <p class="hero-tagline mb-8">Knowledge that compounds.</p>
      <p class="hero-problem mb-10">
        Most organisations don't have a content problem.<br class="hidden md:block" /> They have an evidence problem.
      </p>
      <div class="flex flex-wrap items-center gap-8">
        <a href="/intelligence" class="hero-link-primary">
          What is Editorial Intelligence?
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/narratives" class="hero-link-secondary">
          Explore narratives
        </a>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Hierarchy diagram -->
  <section class="container-site py-16">
    <p class="t-label mb-10">How it works</p>
    <div class="hierarchy">
      {[
        { num: '01', label: 'Editorial Intelligence', sub: 'The discipline', href: '/intelligence' },
        { num: '02', label: 'Evidence Engine', sub: 'The infrastructure', href: '/frameworks/evidence-engine' },
        { num: '03', label: 'EI Cycle', sub: 'The operating model', href: '/intelligence' },
        { num: '04', label: 'Daily OS', sub: 'The daily practice', href: '/frameworks/daily-os' },
        { num: '05', label: 'Applications', sub: 'Proof in the real world', href: '/narratives' },
      ].map((level, i) => (
        <div class="hierarchy-row">
          {i > 0 && <div class="hierarchy-connector" aria-hidden="true">↓</div>}
          <a href={level.href} class="hierarchy-item">
            <span class="hierarchy-num">{level.num}</span>
            <span class="hierarchy-label">{level.label}</span>
            <span class="hierarchy-sub">{level.sub}</span>
          </a>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Who it's for -->
  <section class="container-site py-16">
    <p class="t-label mb-8">Who it's for</p>
    <div class="audience-grid">
      {[
        'Content leaders',
        'CMOs',
        'Thought leadership teams',
        'Research teams',
        'Customer marketing',
        'Product marketing',
        'Corporate communications',
      ].map((role) => (
        <div class="audience-item">{role}</div>
      ))}
    </div>
    <p class="audience-body mt-8">
      Editorial Intelligence is for anyone responsible for turning organisational knowledge into something that compounds — not just publishes.
    </p>
  </section>

  <hr class="divider container-site" />

  <!-- Start here -->
  <section class="container-site pb-8 pt-16">
    <a href="/writing/why-content-work-needs-to-compound" class="origin-callout group">
      <span class="origin-callout-label">Start here</span>
      <span class="origin-callout-text">I was not tired of writing. I was tired of work that disappeared. — Why content work needs to compound</span>
      <span class="origin-callout-arrow group-hover:translate-x-0.5 transition-transform">→</span>
    </a>
  </section>

  <!-- Worked example -->
  {featuredNarrative && (
    <section class="container-site pb-16">
      <div class="section-header mb-8">
        <div>
          <p class="t-label">Worked example</p>
          <p class="section-subhead">See how the cycle operates in practice</p>
        </div>
      </div>
      <NarrativeCard
        slug={featuredNarrative.slug}
        title={featuredNarrative.data.title}
        subtitle={featuredNarrative.data.subtitle}
        excerpt={featuredNarrative.data.excerpt}
        date={featuredNarrative.data.date}
        readTime={featuredNarrative.data.readTime}
        tags={featuredNarrative.data.tags as string[]}
        relatedFrameworks={featuredNarrative.data.relatedFrameworks.length}
        relatedNarratives={featuredNarrative.data.relatedNarratives.length}
        relatedArticles={featuredNarrative.data.relatedArticles.length}
        featured={true}
        startHere={true}
      />

      {featuredRelatedFrameworks.length > 0 && (
        <div class="mt-4">
          <p class="t-mono mb-3 pl-1 opacity-50">Supporting frameworks</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuredRelatedFrameworks.map((fw) => (
              <FrameworkCard
                slug={fw.slug}
                title={fw.data.title}
                subtitle={fw.data.subtitle}
                excerpt={fw.data.excerpt}
                date={fw.data.date}
                type={fw.data.type}
                tags={fw.data.tags as string[]}
                relatedNarratives={fw.data.relatedNarratives.length}
                relatedArticles={fw.data.relatedArticles.length}
              />
            ))}
          </div>
        </div>
      )}

      {featuredRelatedArticles.length > 0 && (
        <div class="mt-4">
          <p class="t-mono mb-3 pl-1 opacity-50">Related writing</p>
          <ul class="related-articles">
            {featuredRelatedArticles.map((article) => (
              <li>
                <a href={`/writing/${article.slug}`} class="related-article-link group">
                  <span class="type-badge type-badge--writing shrink-0">Essay</span>
                  <span class="t-small text-[var(--color-ink-secondary)] group-hover:text-[var(--color-ink)] transition-colors">{article.data.title}</span>
                  <span class="t-mono opacity-40 shrink-0 ml-auto">{article.data.readTime} min</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <hr class="divider container-site" />

  <!-- Frameworks -->
  {remainingFrameworks.length > 0 && (
    <section class="container-site py-16">
      <div class="section-header mb-8">
        <div>
          <p class="t-label">Frameworks</p>
          <p class="section-subhead">Reusable methods and models</p>
        </div>
        <a href="/frameworks" class="section-link">All frameworks →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {remainingFrameworks.map((fw) => (
          <FrameworkCard
            slug={fw.slug}
            title={fw.data.title}
            subtitle={fw.data.subtitle}
            excerpt={fw.data.excerpt}
            date={fw.data.date}
            type={fw.data.type}
            tags={fw.data.tags as string[]}
            relatedNarratives={fw.data.relatedNarratives.length}
            relatedArticles={fw.data.relatedArticles.length}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero-tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    text-transform: uppercase;
    opacity: 0.85;
  }

  .hero-problem {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    line-height: 1.5;
    color: var(--color-ink);
    font-weight: 400;
    letter-spacing: -0.01em;
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    max-width: 44ch;
  }

  .hero-link-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    padding-bottom: 1px;
    transition: border-color 0.2s;
  }

  .hero-link-primary:hover {
    border-color: var(--color-accent);
  }

  .hero-link-secondary {
    font-size: 0.875rem;
    color: var(--color-ink-tertiary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-link-secondary:hover {
    color: var(--color-ink);
  }

  /* Hierarchy */
  .hierarchy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    max-width: 480px;
  }

  .hierarchy-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .hierarchy-connector {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
    opacity: 0.5;
    padding: 0.25rem 0 0.25rem 1.25rem;
    line-height: 1;
  }

  .hierarchy-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    text-decoration: none;
    width: 100%;
    transition: background 0.15s, border-color 0.15s;
  }

  .hierarchy-item:hover {
    background: var(--color-surface-secondary);
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-rule));
  }

  .hierarchy-num {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    grid-row: 1 / 3;
    align-self: center;
    opacity: 0.7;
  }

  .hierarchy-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    display: block;
    margin-bottom: 0.1rem;
  }

  .hierarchy-sub {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-tertiary);
    display: block;
    letter-spacing: 0.03em;
  }

  /* Audience */
  .audience-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .audience-item {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    padding: 0.4rem 0.875rem;
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    background: var(--color-surface-secondary);
  }

  .audience-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-tertiary);
    max-width: 52ch;
  }

  /* Origin callout */
  .origin-callout {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-rule);
    border-left: 2px solid var(--color-accent);
    border-radius: 4px;
    background: var(--color-surface-secondary);
    text-decoration: none;
    transition: background 0.15s;
  }

  .origin-callout:hover {
    background: var(--color-surface-tertiary);
  }

  .origin-callout-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    opacity: 0.8;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .origin-callout-text {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
  }

  .origin-callout-arrow {
    font-size: 0.875rem;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-left: auto;
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-subhead {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    margin-top: 0.25rem;
  }

  .section-link {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  .section-link:hover {
    color: var(--color-ink);
  }

  .related-articles {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-rule, #2c2920);
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-surface-secondary);
  }

  .related-article-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule, #2c2920);
    transition: background 0.15s;
  }

  .related-articles li:last-child .related-article-link {
    border-bottom: none;
  }

  .related-article-link:hover {
    background: var(--color-surface-tertiary);
  }
</style>
