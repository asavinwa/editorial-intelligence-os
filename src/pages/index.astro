---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { SITE } from '../config/site';
import LabSignup from '../components/LabSignup.astro';
---

<BaseLayout>
  <!-- Hero: two-column -->
  <section class="hero-section">
    <div class="container-site hero-grid">
      <!-- Left: text -->
      <div class="hero-text">
        <p class="t-label mb-6">{SITE.author} · Editorial Intelligence practitioner</p>
        <h1 class="t-display text-[var(--color-ink)] mb-4 leading-[1.08]">
          Editorial Intelligence<br />for the AI era
        </h1>
        <p class="hero-oneliner mb-8">
          Editorial Intelligence helps organisations turn scattered evidence, insight and expertise into reusable intelligence that compounds over time.
        </p>
        <p class="hero-problem mb-10">
          Most organisations don't have a content problem. They have an evidence problem.
        </p>
        <div class="hero-ctas mb-8">
          <a href="/intelligence" class="hero-cta-primary">
            What is Editorial Intelligence?
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Start Here callout -->
        <a href="/start" class="guide-callout group">
          <span class="guide-callout-badge">Start</span>
          <div class="guide-callout-body">
            <p class="guide-callout-title">New to Editorial Intelligence?</p>
            <p class="guide-callout-sub">Your orientation guide to the ecosystem and where to begin →</p>
          </div>
        </a>

        <!-- Assessment callout -->
        <a href="/assessment" class="guide-callout group">
          <span class="guide-callout-badge">Assess</span>
          <div class="guide-callout-body">
            <p class="guide-callout-title">Editorial Intelligence Assessment</p>
            <p class="guide-callout-sub">Diagnose your organisation's Editorial Intelligence maturity across five dimensions →</p>
          </div>
        </a>

        <!-- Guide callout -->
        <a href="/guide" class="guide-callout group">
          <span class="guide-callout-badge">New</span>
          <div class="guide-callout-body">
            <p class="guide-callout-title">The AI-enabled Content Writer Guide</p>
            <p class="guide-callout-sub">Learn how experienced writers become Editorial Intelligence practitioners →</p>
          </div>
        </a>

        <!-- AI Visibility Audit callout -->
        <a href="/work/ai-visibility-audit" class="guide-callout group">
          <span class="guide-callout-badge">Audit</span>
          <div class="guide-callout-body">
            <p class="guide-callout-title">AI Visibility Audit</p>
            <p class="guide-callout-sub">Understand how AI systems see your organisation and what is limiting your authority →</p>
          </div>
        </a>

        <div class="hero-credibility">
          <p class="credibility-line">
            Based on work across Sage, Sage Advice, Hidden Hours research, IDC thought leadership and Enterprise Nation.
          </p>
        </div>
      </div>

      <!-- Right: flow diagram -->
      <div class="hero-diagram" aria-hidden="true">
        <div class="flow-diagram">

          <!-- Inputs -->
          <div class="flow-section">
            <p class="flow-section-label">Signals in</p>
            <div class="flow-items">
              <div class="flow-item flow-item--in">
                <svg class="flow-icon" viewBox="0 0 16 16" fill="none"><circle cx="6.5" cy="6.5" r="4" stroke="currentColor" stroke-width="1.25"/><path d="M10 10l3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
                Research
              </div>
              <div class="flow-item flow-item--in">
                <svg class="flow-icon" viewBox="0 0 16 16" fill="none"><path d="M2 4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H9l-3 3v-3H4a2 2 0 0 1-2-2V4z" stroke="currentColor" stroke-width="1.25"/></svg>
                Customer insight
              </div>
              <div class="flow-item flow-item--in">
                <svg class="flow-icon" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.25"/><path d="M2 14c0-3 2.7-5 6-5s6 2 6 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
                Executive expertise
              </div>
              <div class="flow-item flow-item--in">
                <svg class="flow-icon" viewBox="0 0 16 16" fill="none"><rect x="2" y="4" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.25"/><path d="M5 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1M5 8h6M5 11h4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
                Webinars & events
              </div>
              <div class="flow-item flow-item--in">
                <svg class="flow-icon" viewBox="0 0 16 16" fill="none"><path d="M2 12l4-4 3 3 5-7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Market signals
              </div>
            </div>
          </div>

          <!-- Arrow -->
          <div class="flow-connector">
            <div class="flow-connector-track">
              <div class="flow-connector-line"></div>
              <svg class="flow-connector-arrow" viewBox="0 0 10 14" fill="none" width="10" height="14">
                <path d="M5 0v11M1 8l4 5 4-5" stroke="#c8a96e" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>
              </svg>
            </div>
          </div>

          <!-- Engine -->
          <div class="flow-engine">
            <p class="flow-engine-label">Editorial Intelligence</p>
            <p class="flow-engine-verbs">Capture · Connect · Synthesise · Activate</p>
          </div>

          <!-- Arrow -->
          <div class="flow-connector">
            <div class="flow-connector-track">
              <div class="flow-connector-line"></div>
              <svg class="flow-connector-arrow" viewBox="0 0 10 14" fill="none" width="10" height="14">
                <path d="M5 0v11M1 8l4 5 4-5" stroke="#c8a96e" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>
              </svg>
            </div>
          </div>

          <!-- Outputs -->
          <div class="flow-section">
            <p class="flow-section-label">Compound outcomes</p>
            <div class="flow-items">
              {['Authority', 'Thought leadership', 'AI visibility', 'Organisational knowledge'].map(item => (
                <div class="flow-item flow-item--out">{item}</div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- From discipline to implementation -->
  <section class="container-site py-12">
    <p class="t-label mb-8">From discipline to implementation</p>
    <div class="discipline-hierarchy">
      <a href="/intelligence" class="dh-item">
        <span class="dh-num">01</span>
        <div class="dh-body">
          <p class="dh-label">Editorial Intelligence</p>
          <p class="dh-sub">The discipline — how organisations turn evidence into decisions and narratives</p>
        </div>
      </a>
      <div class="dh-connector">↓</div>
      <a href="/editorial-intelligence-os" class="dh-item">
        <span class="dh-num">02</span>
        <div class="dh-body">
          <p class="dh-label">Editorial Intelligence OS</p>
          <p class="dh-sub">The operating system — frameworks, methods, assessments, AI workflows</p>
        </div>
      </a>
      <div class="dh-connector">↓</div>
      <a href="/work" class="dh-item">
        <span class="dh-num">03</span>
        <div class="dh-body">
          <p class="dh-label">Consulting</p>
          <p class="dh-sub">Implementation — helping organisations build the capability</p>
        </div>
      </a>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Narratives: EI in practice -->
  <section class="container-site py-16">
    <div class="section-header mb-10">
      <div>
        <p class="t-label mb-2">Editorial Intelligence in practice</p>
        <p class="section-subhead">Narratives that connect signals into strategic position</p>
      </div>
      <a href="/narratives" class="section-link">All narratives →</a>
    </div>

    <div class="narrative-cards">
      <!-- Hidden Hours -->
      <a href="/narratives/hidden-hours" class="ncard group">
        <div class="ncard-visual ncard-visual--hh" aria-hidden="true">
          <div class="ncard-lines">
            {Array.from({length: 8}).map((_, i) => (
              <div class="ncard-line" style={`opacity: ${0.12 + i * 0.07}; width: ${35 + i * 7}%`}></div>
            ))}
          </div>
          <span class="ncard-num">01</span>
          <span class="ncard-tag">The proof point</span>
        </div>
        <div class="ncard-body">
          <p class="ncard-label">Hidden Hours</p>
          <h3 class="ncard-title group-hover:text-[var(--color-accent)] transition-colors">
            The hidden cost of modern work
          </h3>
          <p class="ncard-excerpt">Research into the operational pressures facing accounting professionals — compliance burden, workflow friction, late payments and business change.</p>
          <span class="ncard-cta">Explore the narrative →</span>
        </div>
      </a>

      <!-- Winning in Small -->
      <a href="/narratives/winning-in-small" class="ncard group">
        <div class="ncard-visual ncard-visual--ws" aria-hidden="true">
          <div class="ncard-diagonals">
            {Array.from({length: 6}).map((_, i) => (
              <div class="ncard-diag" style={`left: ${6 + i * 16}%`}></div>
            ))}
          </div>
          <span class="ncard-num">02</span>
          <span class="ncard-tag">Operational intelligence</span>
        </div>
        <div class="ncard-body">
          <p class="ncard-label">Winning in Small</p>
          <h3 class="ncard-title group-hover:text-[var(--color-accent)] transition-colors">
            Why speed relocates pressure
          </h3>
          <p class="ncard-excerpt">Speed doesn't remove pressure. It relocates it. A narrative about what it takes to operate effectively as complexity grows faster than visibility.</p>
          <span class="ncard-cta">Explore the narrative →</span>
        </div>
      </a>

      <!-- Trusted AI -->
      <a href="/narratives/trusted-ai" class="ncard group">
        <div class="ncard-visual ncard-visual--tai" aria-hidden="true">
          <div class="ncard-dots">
            {Array.from({length: 20}).map(() => (
              <div class="ncard-dot"></div>
            ))}
          </div>
          <span class="ncard-num">03</span>
          <span class="ncard-tag">AI narrative</span>
        </div>
        <div class="ncard-body">
          <p class="ncard-label">Trusted AI</p>
          <h3 class="ncard-title group-hover:text-[var(--color-accent)] transition-colors">
            AI trust is built through connected evidence
          </h3>
          <p class="ncard-excerpt">AI trust is not built through claims about innovation. It is built through connected evidence — how AI is governed, how humans remain accountable.</p>
          <span class="ncard-cta">Explore the narrative →</span>
        </div>
      </a>
    </div>
  </section>


  <hr class="divider container-site" />

  <!-- Who it's for -->
  <section class="container-site py-12">
    <p class="t-label mb-6">Who Editorial Intelligence is for</p>
    <div class="audiences-grid">
      <div class="audience-item">
        <p class="audience-title">Content and editorial teams</p>
        <p class="audience-desc">Build systems that turn organisational expertise into reusable intelligence, rather than publishing once and starting again.</p>
      </div>
      <div class="audience-item">
        <p class="audience-title">Marketing and communications</p>
        <p class="audience-desc">Connect research, customer evidence and market signals into narratives that compound over time and improve AI visibility.</p>
      </div>
      <div class="audience-item">
        <p class="audience-title">Product and research teams</p>
        <p class="audience-desc">Connect customer evidence, product signals and market insight to improve prioritisation, alignment and decision-making. <a href="/frameworks/editorial-intelligence-product-management" class="audience-link">See the product framework →</a></p>
      </div>
      <div class="audience-item">
        <p class="audience-title">Knowledge and strategy functions</p>
        <p class="audience-desc">Create the infrastructure that prevents institutional knowledge from disappearing into meetings, inboxes and individual memory.</p>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Start here -->
  <section class="container-site py-12">
    <a href="/writing/why-content-work-needs-to-compound" class="origin-callout group">
      <span class="origin-callout-label">Start here</span>
      <span class="origin-callout-text">I was not tired of writing. I was tired of work that disappeared. — Why content work needs to compound</span>
      <span class="origin-callout-arrow group-hover:translate-x-0.5 transition-transform">→</span>
    </a>
    <p class="in-public-note">
      Editorial Intelligence is being developed in public. External responses and cross-sector applications will help shape what it becomes.
    </p>
    <LabSignup headline="Follow the discipline as it develops" />
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(5rem, 10vw, 8rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .hero-text {
    max-width: 56ch;
  }

  .hero-oneliner {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-ink-secondary);
    font-weight: 400;
    max-width: 50ch;
  }

  .hero-oneliner-sub {
    font-size: clamp(0.875rem, 1.4vw, 0.9375rem);
    line-height: 1.7;
    color: var(--color-ink-tertiary);
    max-width: 50ch;
  }

  .hero-problem {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    line-height: 1.5;
    color: var(--color-ink);
    font-weight: 400;
    letter-spacing: -0.01em;
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    max-width: 40ch;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    padding-bottom: 1px;
    transition: border-color 0.2s;
  }

  .hero-cta-primary:hover {
    border-color: var(--color-accent);
  }

  .hero-cta-guide {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-cta-guide:hover {
    color: var(--color-ink-secondary);
    border-color: color-mix(in srgb, var(--color-ink-tertiary) 35%, transparent);
  }

  /* ── Guide callout ── */
  .guide-callout {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-rule);
    border-left: 2px solid var(--color-accent);
    border-radius: 4px;
    background: var(--color-surface-secondary);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    margin-bottom: 1.75rem;
  }

  .guide-callout:hover {
    background: var(--color-surface-tertiary);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-rule));
  }

  .guide-callout-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .guide-callout-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .guide-callout-sub {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    line-height: 1.5;
    transition: color 0.15s;
  }

  .guide-callout:hover .guide-callout-sub {
    color: var(--color-ink-secondary);
  }

  /* ── Credibility ── */
  .hero-credibility {
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule);
  }

  .credibility-line {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-ink-tertiary);
    max-width: 50ch;
  }

  /* ── Flow diagram ── */
  .hero-diagram {
    display: none;
  }

  @media (min-width: 900px) {
    .hero-diagram {
      display: flex;
      align-items: stretch;
    }
  }

  .flow-diagram {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.75rem 1.5rem;
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-rule);
    border-radius: 6px;
  }

  .flow-section {
    width: 100%;
  }

  .flow-section-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-tertiary);
    opacity: 0.55;
    text-align: center;
    margin-bottom: 0.6rem;
  }

  .flow-items {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .flow-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.375rem 0.75rem;
    border-radius: 3px;
  }

  .flow-item--in {
    background: color-mix(in srgb, var(--color-accent) 7%, transparent);
    color: var(--color-ink-secondary);
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .flow-item--out {
    background: color-mix(in srgb, var(--color-accent) 11%, transparent);
    color: var(--color-ink);
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
    font-weight: 450;
  }

  .flow-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--color-accent);
    opacity: 0.65;
  }

  /* Connector */
  .flow-connector {
    display: flex;
    justify-content: center;
    padding: 0.2rem 0;
  }

  .flow-connector-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .flow-connector-line {
    width: 1px;
    height: 1rem;
    background: linear-gradient(to bottom, color-mix(in srgb, var(--color-accent) 20%, transparent), color-mix(in srgb, var(--color-accent) 50%, transparent));
  }

  .flow-connector-arrow {
    margin-top: -1px;
    opacity: 0.5;
  }

  /* Engine */
  .flow-engine {
    width: 100%;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface));
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    text-align: center;
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-accent) 12%, transparent),
                inset 0 0 20px color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .flow-engine-label {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 0.35rem;
    letter-spacing: -0.01em;
  }

  .flow-engine-verbs {
    font-family: var(--font-mono);
    font-size: 0.6125rem;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  /* ── Beyond / More than content ── */
  .beyond-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .beyond-block {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .beyond-body {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-ink-secondary);
    max-width: 52ch;
    margin-bottom: 0.875rem;
  }

  .beyond-body:last-child {
    margin-bottom: 0;
  }

  .beyond-audiences-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-tertiary);
    opacity: 0.6;
    margin-bottom: 0.75rem;
  }

  .beyond-audience-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 1rem;
  }

  .beyond-audience-item {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-rule);
    border-radius: 3px;
    background: var(--color-surface-secondary);
  }

  .beyond-audiences-note {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-ink-tertiary);
    border-top: 1px solid var(--color-rule);
    padding-top: 0.875rem;
    max-width: 40ch;
  }

  /* ── In public note ── */
  .audiences-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    overflow: hidden;
  }

  @media (max-width: 560px) {
    .audiences-grid { grid-template-columns: 1fr; }
  }

  .audience-item {
    background: var(--color-surface);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .audience-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.3;
  }

  .audience-desc {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-ink-tertiary);
  }

  .audience-link {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .audience-link:hover { opacity: 0.75; }

  .in-public-note {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.04em;
    line-height: 1.7;
    color: var(--color-ink-tertiary);
    opacity: 0.5;
    margin-top: 1.25rem;
    max-width: 60ch;
  }

  /* ── Section header ── */
