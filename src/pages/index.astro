---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout>
  <!-- Hero: two-column -->
  <section class="hero-section">
    <div class="container-site hero-grid">
      <!-- Left: text -->
      <div class="hero-text">
        <p class="t-label mb-6">{SITE.author} · Content strategist at Sage</p>
        <h1 class="t-display text-[var(--color-ink)] mb-4 leading-[1.08]">
          Editorial Intelligence<br />for the AI era
        </h1>
        <p class="hero-oneliner mb-8">
          I help organisations turn research, customer insight and expertise into connected narratives that build authority, visibility and impact over time.
        </p>
        <p class="hero-problem mb-10">
          Most organisations don't have a content problem. They have an evidence problem.
        </p>
        <div class="hero-ctas">
          <a href="/intelligence" class="hero-cta-primary">
            What is Editorial Intelligence?
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/guide" class="hero-cta-guide">
            The AI-enabled Content Writer Guide →
          </a>
        </div>

        <div class="hero-credibility">
          <p class="credibility-line">
            Developed through work with Sage, customer research, executive thought leadership and AI experimentation.
          </p>
          <p class="credibility-tags">
            Sage&nbsp;· Sage Advice&nbsp;· IDC&nbsp;· Enterprise Nation&nbsp;· Hidden Hours&nbsp;· #1 "Editorial Intelligence"
          </p>
        </div>
      </div>

      <!-- Right: flow diagram -->
      <div class="hero-diagram" aria-hidden="true">
        <div class="flow-diagram">
          <!-- Inputs -->
          <div class="flow-section flow-section--inputs">
            <p class="flow-section-label">Inputs</p>
            <div class="flow-items">
              {['Research', 'Customer insight', 'Executive expertise', 'Events', 'Market signals'].map(item => (
                <div class="flow-item flow-item--in">{item}</div>
              ))}
            </div>
          </div>

          <!-- Arrow down -->
          <div class="flow-arrow" aria-hidden="true">
            <div class="flow-arrow-line"></div>
            <div class="flow-arrow-head">↓</div>
          </div>

          <!-- Engine -->
          <div class="flow-engine">
            <p class="flow-engine-label">Editorial Intelligence</p>
            <p class="flow-engine-verbs">Capture · Connect · Synthesise · Activate</p>
          </div>

          <!-- Arrow down -->
          <div class="flow-arrow" aria-hidden="true">
            <div class="flow-arrow-line"></div>
            <div class="flow-arrow-head">↓</div>
          </div>

          <!-- Outputs -->
          <div class="flow-section flow-section--outputs">
            <p class="flow-section-label">Outputs</p>
            <div class="flow-items">
              {['Thought leadership', 'Authority', 'AI visibility', 'Demand generation', 'Organisational knowledge'].map(item => (
                <div class="flow-item flow-item--out">{item}</div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Narratives: EI in practice -->
  <section class="container-site py-16">
    <div class="section-header mb-10">
      <div>
        <p class="t-label mb-2">Editorial Intelligence in practice</p>
        <p class="section-subhead">Narratives that connect signals into strategic position</p>
      </div>
      <a href="/narratives" class="section-link">All narratives →</a>
    </div>

    <div class="narrative-cards">
      <!-- Hidden Hours -->
      <a href="/narratives/hidden-hours" class="ncard group">
        <div class="ncard-visual ncard-visual--hh" aria-hidden="true">
          <div class="ncard-lines">
            {Array.from({length: 8}).map((_, i) => (
              <div class="ncard-line" style={`opacity: ${0.12 + i * 0.07}; width: ${35 + i * 7}%`}></div>
            ))}
          </div>
          <span class="ncard-num">01</span>
          <span class="ncard-tag">The proof point</span>
        </div>
        <div class="ncard-body">
          <p class="ncard-label">Hidden Hours</p>
          <h3 class="ncard-title group-hover:text-[var(--color-accent)] transition-colors">
            The hidden cost of modern work
          </h3>
          <p class="ncard-excerpt">Research into the operational pressures facing accounting professionals — compliance burden, workflow friction, late payments and business change.</p>
          <span class="ncard-cta">Explore the narrative →</span>
        </div>
      </a>

      <!-- Winning in Small -->
      <a href="/narratives/winning-in-small" class="ncard group">
        <div class="ncard-visual ncard-visual--ws" aria-hidden="true">
          <div class="ncard-diagonals">
            {Array.from({length: 6}).map((_, i) => (
              <div class="ncard-diag" style={`left: ${6 + i * 16}%`}></div>
            ))}
          </div>
          <span class="ncard-num">02</span>
          <span class="ncard-tag">Operational intelligence</span>
        </div>
        <div class="ncard-body">
          <p class="ncard-label">Winning in Small</p>
          <h3 class="ncard-title group-hover:text-[var(--color-accent)] transition-colors">
            Why speed relocates pressure
          </h3>
          <p class="ncard-excerpt">Speed doesn't remove pressure. It relocates it. A narrative about what it takes to operate effectively as complexity grows faster than visibility.</p>
          <span class="ncard-cta">Explore the narrative →</span>
        </div>
      </a>

      <!-- Trusted AI -->
      <a href="/narratives/trusted-ai" class="ncard group">
        <div class="ncard-visual ncard-visual--tai" aria-hidden="true">
          <div class="ncard-dots">
            {Array.from({length: 20}).map(() => (
              <div class="ncard-dot"></div>
            ))}
          </div>
          <span class="ncard-num">03</span>
          <span class="ncard-tag">AI narrative</span>
        </div>
        <div class="ncard-body">
          <p class="ncard-label">Trusted AI</p>
          <h3 class="ncard-title group-hover:text-[var(--color-accent)] transition-colors">
            AI trust is built through connected evidence
          </h3>
          <p class="ncard-excerpt">AI trust is not built through claims about innovation. It is built through connected evidence — how AI is governed, how humans remain accountable.</p>
          <span class="ncard-cta">Explore the narrative →</span>
        </div>
      </a>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Guide CTA -->
  <section class="container-site py-16">
    <div class="guide-block">
      <div class="guide-block-text">
        <p class="t-label mb-3">For content writers</p>
        <h2 class="guide-title">The AI-enabled Content Writer Guide</h2>
        <p class="guide-desc">
          A practical guide to working at the intersection of editorial judgement and AI capability — covering strategy, prompting, workflow and the skills that compound over time.
        </p>
        <a href="/guide" class="guide-cta">
          Read the guide
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div class="guide-block-meta">
        <div class="guide-meta-item">
          <span class="guide-meta-num">7</span>
          <span class="guide-meta-label">Parts</span>
        </div>
        <div class="guide-meta-item">
          <span class="guide-meta-num">90</span>
          <span class="guide-meta-label">Day plan</span>
        </div>
        <div class="guide-meta-item">
          <span class="guide-meta-num">∞</span>
          <span class="guide-meta-label">Compounds</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider container-site" />

  <!-- Start here -->
  <section class="container-site py-12">
    <a href="/writing/why-content-work-needs-to-compound" class="origin-callout group">
      <span class="origin-callout-label">Start here</span>
      <span class="origin-callout-text">I was not tired of writing. I was tired of work that disappeared. — Why content work needs to compound</span>
      <span class="origin-callout-arrow group-hover:translate-x-0.5 transition-transform">→</span>
    </a>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(5rem, 10vw, 8rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .hero-text {
    max-width: 56ch;
  }

  .hero-oneliner {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-ink-secondary);
    font-weight: 400;
    max-width: 50ch;
  }

  .hero-problem {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    line-height: 1.5;
    color: var(--color-ink);
    font-weight: 400;
    letter-spacing: -0.01em;
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    max-width: 40ch;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    padding-bottom: 1px;
    transition: border-color 0.2s;
  }

  .hero-cta-primary:hover {
    border-color: var(--color-accent);
  }

  .hero-cta-guide {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-cta-guide:hover {
    color: var(--color-ink-secondary);
    border-color: color-mix(in srgb, var(--color-ink-tertiary) 35%, transparent);
  }

  /* ── Credibility ── */
  .hero-credibility {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .credibility-line {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-ink-tertiary);
    max-width: 50ch;
    margin-bottom: 0.625rem;
  }

  .credibility-tags {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.07em;
    color: var(--color-accent);
    opacity: 0.6;
    line-height: 1.8;
  }

  /* ── Flow diagram ── */
  .hero-diagram {
    display: none;
  }

  @media (min-width: 900px) {
    .hero-diagram {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  .flow-diagram {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 2rem 1.5rem;
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-rule);
    border-radius: 6px;
  }

  .flow-section {
    width: 100%;
  }

  .flow-section-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-tertiary);
    opacity: 0.6;
    text-align: center;
    margin-bottom: 0.625rem;
  }

  .flow-items {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .flow-item {
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.4rem 0.875rem;
    border-radius: 3px;
    text-align: center;
  }

  .flow-item--in {
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    color: var(--color-ink-secondary);
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .flow-item--out {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-ink);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .flow-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0.25rem 0;
  }

  .flow-arrow-line {
    width: 1px;
    height: 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .flow-arrow-head {
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0.5;
    line-height: 1;
  }

  .flow-engine {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    text-align: center;
  }

  .flow-engine-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }

  .flow-engine-verbs {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    opacity: 0.75;
  }

  /* ── Section header ── */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-subhead {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    margin-top: 0.25rem;
  }

  .section-link {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .section-link:hover {
    color: var(--color-ink);
  }

  /* ── Narrative cards ── */
  .narrative-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .narrative-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ncard {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .ncard:hover {
    border-color: color-mix(in srgb, var(--color-accent) 35%, var(--color-rule));
  }

  /* Visual area */
  .ncard-visual {
    height: 190px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ncard-visual--hh {
    background: linear-gradient(160deg, #241d10 0%, #1a1509 60%, #1e1a0e 100%);
  }

  .ncard-visual--ws {
    background: linear-gradient(160deg, #101820 0%, #0c141c 60%, #111921 100%);
  }

  .ncard-visual--tai {
    background: linear-gradient(160deg, #141418 0%, #0f0f14 60%, #12121a 100%);
  }

  /* Hidden Hours: stacked document lines */
  .ncard-lines {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.5rem 1.25rem 0;
  }

  .ncard-line {
    height: 1px;
    background: #c8a96e;
    border-radius: 1px;
  }

  /* Winning in Small: diagonal speed lines */
  .ncard-diagonals {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .ncard-diag {
    position: absolute;
    top: -20%;
    bottom: -20%;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(120, 180, 220, 0.22) 30%, rgba(120, 180, 220, 0.22) 70%, transparent);
    transform: skewX(-14deg);
  }

  /* Trusted AI: dot grid */
  .ncard-dots {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.8rem;
    padding: 1.5rem 1.25rem 0;
  }

  .ncard-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(160, 160, 200, 0.28);
    justify-self: center;
  }

  .ncard-dots .ncard-dot:nth-child(3),
  .ncard-dots .ncard-dot:nth-child(7),
  .ncard-dots .ncard-dot:nth-child(13),
  .ncard-dots .ncard-dot:nth-child(18) {
    background: rgba(200, 169, 110, 0.55);
    width: 5px;
    height: 5px;
  }

  .ncard-num {
    font-family: var(--font-mono);
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.07;
    position: absolute;
    bottom: 0.25rem;
    right: 0.875rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .ncard-tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    opacity: 0.75;
    text-transform: uppercase;
    position: absolute;
    bottom: 1rem;
    left: 1.25rem;
  }

  .ncard-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    background: var(--color-surface-secondary);
  }

  .ncard-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    text-transform: uppercase;
    opacity: 0.75;
    margin: 0;
  }

  .ncard-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.35;
    margin: 0;
  }

  .ncard-excerpt {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-ink-tertiary);
    margin: 0;
    flex: 1;
  }

  .ncard-cta {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .ncard:hover .ncard-cta {
    opacity: 1;
  }

  /* ── Guide block ── */
  .guide-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding: 2rem 2rem 2rem 2rem;
    border: 1px solid var(--color-rule);
    border-left: 2px solid var(--color-accent);
    border-radius: 4px;
    background: var(--color-surface-secondary);
  }

  @media (min-width: 640px) {
    .guide-block {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }

  .guide-title {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .guide-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    max-width: 60ch;
    margin-bottom: 1.25rem;
  }

  .guide-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    padding-bottom: 1px;
    transition: border-color 0.2s;
  }

  .guide-cta:hover {
    border-color: var(--color-accent);
  }

  .guide-block-meta {
    display: flex;
    gap: 2rem;
    flex-shrink: 0;
  }

  .guide-meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .guide-meta-num {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1;
  }

  .guide-meta-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.08em;
    color: var(--color-ink-tertiary);
    text-transform: uppercase;
  }

  /* ── Origin callout ── */
  .origin-callout {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-rule);
    border-left: 2px solid var(--color-accent);
    border-radius: 4px;
    background: var(--color-surface-secondary);
    text-decoration: none;
    transition: background 0.15s;
  }

  .origin-callout:hover {
    background: var(--color-surface-tertiary);
  }

  .origin-callout-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    opacity: 0.8;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .origin-callout-text {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
  }

  .origin-callout-arrow {
    font-size: 0.875rem;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-left: auto;
  }
</style>
