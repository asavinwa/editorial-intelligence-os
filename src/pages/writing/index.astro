---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import WritingRow from '../../components/content/WritingRow.astro';
import { getCollection } from 'astro:content';

const writing = await getCollection('writing', ({ data }) => data.status === 'published');
const sorted = writing.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const articles = sorted.filter(w => w.data.type === 'article' || w.data.type === 'reflection');
const notes = sorted.filter(w => w.data.type === 'note');
---

<BaseLayout
  title="Writing"
  description="Articles, notes and reflections on editorial intelligence, knowledge systems and the AI era."
>
  <div class="container-site py-16">
    <header class="mb-12 max-w-2xl">
      <p class="t-label mb-4">Writing</p>
      <h1 class="t-heading mb-4">Articles and notes</h1>
      <p class="t-body">
        Shorter pieces exploring the ideas behind Editorial Intelligence — evidence that feeds the larger narratives.
      </p>
    </header>

    <hr class="divider mb-12" />

    {articles.length > 0 && (
      <section class="mb-16">
        <p class="t-label mb-6">Articles & reflections</p>
        <ul class="m-0 p-0">
          {articles.map((article) => (
            <WritingRow
              slug={article.slug}
              title={article.data.title}
              date={article.data.date}
              readTime={article.data.readTime}
              type={article.data.type}
            />
          ))}
        </ul>
      </section>
    )}

    {notes.length > 0 && (
      <section>
        <p class="t-label mb-2">Signal notes</p>
        <p class="t-small mb-6" style="color: var(--color-ink-tertiary)">Observations on source material that feeds the EI OS — research, articles and events.</p>
        <ul class="m-0 p-0">
          {notes.map((article) => (
            <WritingRow
              slug={article.slug}
              title={article.data.title}
              date={article.data.date}
              readTime={article.data.readTime}
              type={article.data.type}
            />
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
