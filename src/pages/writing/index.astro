---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const writing = await getCollection('writing', ({ data }) => data.status === 'published');
const sorted = writing.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const essays = sorted.filter(w => w.data.type === 'article' || w.data.type === 'reflection');
const notes = sorted.filter(w => w.data.type === 'note');

const featured = essays[0];
const rest = essays.slice(1);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en-GB', { year: 'numeric', month: 'short', day: 'numeric' }).format(date);
}
---

<BaseLayout
  title="Field Notes"
  description="Essays and field notes on editorial intelligence, knowledge systems and the AI era."
>
  <div class="container-site py-16">

    <header class="mb-12 max-w-2xl">
      <p class="t-label mb-4">Field Notes</p>
      <h1 class="t-heading mb-4">Essays and field notes</h1>
      <p class="t-body">
        Thinking in progress — essays on editorial intelligence, knowledge systems and the AI era, alongside signal notes from research, events and the field.
      </p>
    </header>

    <hr class="divider mb-14" />

    <!-- Featured essay -->
    {featured && (
      <div class="mb-14">
        <p class="t-label mb-6">Latest essay</p>
        <a href={`/writing/${featured.slug}`} class="featured-essay group">
          <div class="featured-essay-meta">
            <span class="essay-type-badge">{featured.data.type}</span>
            <span class="featured-essay-date">{formatDate(featured.data.date)}</span>
            <span class="featured-essay-read">{featured.data.readTime} min</span>
          </div>
          <h2 class="featured-essay-title group-hover:text-[var(--color-accent)] transition-colors">
            {featured.data.title}
          </h2>
          <p class="featured-essay-excerpt">{featured.data.excerpt}</p>
          <span class="featured-essay-cta">Read →</span>
        </a>
      </div>
    )}

    <!-- Essay grid -->
    {rest.length > 0 && (
      <div class="mb-16">
        <p class="t-label mb-6">Essays</p>
        <div class="essay-grid">
          {rest.map(essay => (
            <a href={`/writing/${essay.slug}`} class="essay-card group">
              <div class="essay-card-meta">
                <span class="essay-type-badge">{essay.data.type}</span>
                <span class="essay-card-date">{formatDate(essay.data.date)}</span>
              </div>
              <h3 class="essay-card-title group-hover:text-[var(--color-accent)] transition-colors">
                {essay.data.title}
              </h3>
              <p class="essay-card-excerpt">{essay.data.excerpt}</p>
              <span class="essay-card-read">{essay.data.readTime} min read</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <hr class="divider mb-12" />

    <!-- Signal notes -->
    {notes.length > 0 && (
      <div>
        <div class="notes-header mb-6">
          <p class="t-label">Signal notes</p>
          <p class="notes-desc">Observations from research, events and source material that feeds the EI OS.</p>
        </div>
        <div class="notes-list">
          {notes.map(note => (
            <a href={`/writing/${note.slug}`} class="note-row group">
              <div class="note-row-left">
                <span class="note-row-title group-hover:text-[var(--color-ink)] transition-colors">{note.data.title}</span>
                <span class="note-row-excerpt">{note.data.excerpt}</span>
              </div>
              <div class="note-row-right">
                <span class="note-row-date">{formatDate(note.data.date)}</span>
                <span class="note-row-read">{note.data.readTime} min</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</BaseLayout>

<style>
  /* ── Featured essay ── */
  .featured-essay {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    border: 1px solid var(--color-rule);
    border-left: 2px solid var(--color-accent);
    border-radius: 4px;
    background: var(--color-surface-secondary);
    text-decoration: none;
    transition: background 0.15s;
  }

  .featured-essay:hover {
    background: var(--color-surface-tertiary);
  }

  .featured-essay-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .featured-essay-date,
  .featured-essay-read {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    opacity: 0.7;
  }

  .featured-essay-title {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.5vw, 1.45rem);
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .featured-essay-excerpt {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-secondary);
    max-width: 68ch;
  }

  .featured-essay-cta {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  /* ── Type badge ── */
  .essay-type-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
    opacity: 0.8;
  }

  /* ── Essay grid ── */
  .essay-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .essay-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .essay-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    background: var(--color-surface-secondary);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .essay-card:hover {
    background: var(--color-surface-tertiary);
    border-color: color-mix(in srgb, var(--color-accent) 25%, var(--color-rule));
  }

  .essay-card-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .essay-card-date {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    opacity: 0.6;
  }

  .essay-card-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.35;
    flex: 1;
  }

  .essay-card-excerpt {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-ink-tertiary);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .essay-card-read {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    opacity: 0.5;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* ── Signal notes ── */
  .notes-header {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .notes-desc {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    line-height: 1.6;
    max-width: 52ch;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    overflow: hidden;
  }

  .note-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-surface-secondary);
    text-decoration: none;
    transition: background 0.15s;
  }

  .note-row:last-child {
    border-bottom: none;
  }

  .note-row:hover {
    background: var(--color-surface-tertiary);
  }

  .note-row-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .note-row-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    line-height: 1.4;
  }

  .note-row-excerpt {
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-ink-tertiary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .note-row-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .note-row-date {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    opacity: 0.6;
    white-space: nowrap;
  }

  .note-row-read {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    opacity: 0.4;
  }
</style>
